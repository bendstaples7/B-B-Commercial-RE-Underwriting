# Database Configuration

# PostgreSQL connection string — update host/credentials for your environment
# Production (VPS): postgresql://deploy@localhost:5432/real_estate_analysis
# Local development: postgresql://postgres:postgres@localhost:5432/real_estate_analysis
DATABASE_URL=postgresql://localhost/real_estate_analysis

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# External API Keys
MLS_API_KEY=your-mls-api-key
TAX_ASSESSOR_API_KEY=your-tax-assessor-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
CHICAGO_DATA_API_KEY=your-chicago-data-api-key
SOCRATA_APP_TOKEN=  # Optional: Cook County Assessor API app token for higher rate limits
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
RENTCAST_API_KEY=your-rentcast-api-key    # RentCast API for market rent estimates (https://developers.rentcast.io)

# Optional: Cook County Socrata app token — increases rate limit from 1,000 to 50,000 req/day
# Register at https://data.cookcountyil.gov/profile/app_tokens
COOK_COUNTY_APP_TOKEN=

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Async Processing Configuration
# Set to 'true' to use Celery for async comparable search (requires Redis + Celery worker)
# Set to 'false' to run comparable search synchronously (works without any infrastructure)
# Default: false (synchronous mode for easier local development)
USE_ASYNC_COMPARABLE_SEARCH=false

# HubSpot CRM Migration
# Must be a valid 32-byte URL-safe base64-encoded Fernet key.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HUBSPOT_ENCRYPTION_KEY=your-fernet-key-here

# HubSpot Webhook Sync
HUBSPOT_CLIENT_SECRET=

# Optional: how often to sync HubSpot engagements (notes/calls/tasks) in minutes.
# Engagements cannot be delivered via webhook, so this scheduled job fills the gap.
# Default: 60 (every hour). Set lower for more frequent syncs.
HUBSPOT_ENGAGEMENT_SYNC_INTERVAL_MINUTES=60
